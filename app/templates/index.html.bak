<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Ocean Prototype UI</title>
  <style>
    :root {
      --bg: #f5f7fb;
      --panel: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --border: #dbe3ef;
      --accent: #2563eb;
      --accent-soft: #dbeafe;
      --success: #166534;
      --success-bg: #dcfce7;
      --error: #991b1b;
      --error-bg: #fee2e2;
      --busy: #16a34a;
      --busy-glow: rgba(22, 163, 74, 0.35);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Inter, system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .wrap {
      max-width: 1380px;
      margin: 0 auto;
      padding: 24px;
    }

    h1, h2, h3 {
      margin-top: 0;
    }

    .layout {
      display: grid;
      grid-template-columns: 420px minmax(520px, 1fr);
      gap: 20px;
      align-items: start;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 18px;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    label {
      display: block;
      font-size: 14px;
      font-weight: 700;
      margin: 14px 0 6px;
    }

    select,
    input[type="number"],
    button {
      width: 100%;
      font: inherit;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid #cfd8e3;
      box-sizing: border-box;
    }

    button {
      border: 0;
      background: var(--accent);
      color: white;
      font-weight: 700;
      cursor: pointer;
      margin-top: 16px;
      transition: transform 0.15s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    button:hover:not(:disabled) {
      transform: translateY(-1px);
    }

    button.busy {
      background: var(--busy);
      animation: breathe 1.8s ease-in-out infinite;
      box-shadow: 0 0 0 0 var(--busy-glow);
    }

    @keyframes breathe {
      0% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.20);
        filter: brightness(0.96);
      }
      50% {
        transform: scale(1.015);
        box-shadow: 0 0 0 12px rgba(22, 163, 74, 0.00);
        filter: brightness(1.08);
      }
      100% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.00);
        filter: brightness(0.96);
      }
    }

    .status {
      white-space: pre-wrap;
      background: #eef2ff;
      color: #3730a3;
      padding: 12px;
      border-radius: 12px;
      min-height: 68px;
    }

    .status.success {
      background: var(--success-bg);
      color: var(--success);
    }

    .status.error {
      background: var(--error-bg);
      color: var(--error);
    }

    .hint {
      color: var(--muted);
      font-size: 14px;
    }

    .downloads a {
      display: inline-block;
      margin: 6px 8px 0 0;
      padding: 8px 12px;
      background: var(--accent-soft);
      color: var(--accent);
      text-decoration: none;
      border-radius: 10px;
      font-weight: 600;
    }

    .summary-item {
      display: flex;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
      padding: 8px 0;
      font-size: 14px;
    }

    pre {
      white-space: pre-wrap;
      word-break: break-word;
      background: #f8fafc;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 12px;
      overflow: auto;
      min-height: 120px;
    }

    .preview-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
      font-size: 14px;
      color: var(--muted);
    }

    #preview-image {
      width: 100%;
      min-height: 560px;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: #eef4fb;
      object-fit: contain;
      display: block;
    }

    .region-picker {
      margin-top: 14px;
    }

    .progress-track {
      width: 100%;
      height: 12px;
      background: #e5edf5;
      border-radius: 999px;
      overflow: hidden;
      margin-top: 8px;
      margin-bottom: 8px;
      border: 1px solid #dbe3ef;
    }

    .progress-bar {
      width: 0%;
      height: 100%;
      background: linear-gradient(90deg, #2563eb, #16a34a);
      transition: width 0.35s ease;
    }

    @media (max-width: 1150px) {
      .layout {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>Ocean Prototype UI</h1>

    <div class="layout">
      <section class="panel">
        <label for="demo_file">Demo dataset</label>
        <select id="demo_file">
          <option value="">-- choose demo file --</option>
          {% for item in demo_files %}
          <option value="{{ item }}">{{ item }}</option>
          {% endfor %}
        </select>

        <label for="preset">Preset</label>
        <select id="preset">
          {% for key, preset in presets.items() %}
          <option value="{{ key }}">{{ preset.label }}</option>
          {% endfor %}
        </select>

        <label for="export_mode">Export mode</label>
        <select id="export_mode">
          <option value="single_stl">Single STL</option>
          <option value="separate_regions_zip">Separate regions ZIP</option>
          <option value="scad_only">SCAD only</option>
        </select>

        <label for="source_max">Source max</label>
        <input id="source_max" type="number" min="1000" step="1000" value="100000">

        <button id="generate-button" type="button">Generate</button>

        <h3 style="margin-top:20px;">Status</h3>
        <div id="status-box" class="status">Ready.</div>

        <div style="margin-top:12px;">
          <div class="hint" id="progress-label">No active job.</div>
          <div class="progress-track">
            <div id="progress-bar" class="progress-bar"></div>
          </div>
          <div class="hint" id="eta-label">Estimated time remaining: —</div>
        </div>

        <h3 style="margin-top:20px;">Job Info</h3>
        <div id="job-info" class="hint">No job yet.</div>

        <h3 style="margin-top:20px;">Downloads</h3>
        <div id="downloads" class="downloads">No downloads yet.</div>

        <h3 style="margin-top:20px;">Summary</h3>
        <div id="summary-box" class="hint">No summary yet.</div>

        <h3 style="margin-top:20px;">Processing Details</h3>
        <pre id="raw-response">Script loaded.</pre>
      </section>

      <section class="panel">
        <div class="preview-meta">
          <div>
            <h2 style="margin-bottom:4px;">Preview</h2>
            <div id="preview-status">No preview yet.</div>
          </div>
          <div class="hint">
            Server-rendered PNG preview
          </div>
        </div>

        <img id="preview-image" alt="Generated preview">

        <div class="region-picker" id="region-picker-wrap" style="display:none;">
          <label for="region-preview-select">Region preview</label>
          <select id="region-preview-select"></select>
        </div>
      </section>
    </div>
  </div>

  <script>
    var statusBox = document.getElementById("status-box");
    var rawBox = document.getElementById("raw-response");
    var downloadsBox = document.getElementById("downloads");
    var summaryBox = document.getElementById("summary-box");
    var jobInfoBox = document.getElementById("job-info");
    var button = document.getElementById("generate-button");
    var previewStatus = document.getElementById("preview-status");
    var previewImage = document.getElementById("preview-image");
    var regionPreviewWrap = document.getElementById("region-picker-wrap");
    var regionPreviewSelect = document.getElementById("region-preview-select");
    var progressBar = document.getElementById("progress-bar");
    var progressLabel = document.getElementById("progress-label");
    var etaLabel = document.getElementById("eta-label");

    var currentJobId = null;
    var pollTimer = null;
    var latestRegionFiles = [];

    function setStatus(text, kind) {
      statusBox.className = "status";
      if (kind) {
        statusBox.className += " " + kind;
      }
      statusBox.textContent = text;
    }

    function setBusy(isBusy) {
      if (isBusy) {
        button.disabled = true;
        button.className = "busy";
        button.textContent = "Generating...";
      } else {
        button.disabled = false;
        button.className = "";
        button.textContent = "Generate";
      }
    }

    function setPreviewStatus(text) {
      previewStatus.textContent = text;
    }

    function clearPreview() {
      previewImage.removeAttribute("src");
    }

    function updatePreview(url) {
      if (!url) {
        setPreviewStatus("No PNG preview available.");
        clearPreview();
        return;
      }

      var absoluteUrl = new URL(url, window.location.origin).toString();
      var cacheBustedUrl = absoluteUrl + (absoluteUrl.includes("?") ? "&" : "?") + "t=" + Date.now();

      setPreviewStatus("Loading PNG preview...");
      previewImage.src = cacheBustedUrl;
    }

    previewImage.addEventListener("load", function () {
      setPreviewStatus("PNG preview loaded.");
    });

    previewImage.addEventListener("error", function () {
      setPreviewStatus("Failed to load PNG preview.");
    });

    function formatEta(seconds) {
      if (seconds === null || seconds === undefined) return "—";
      if (seconds <= 0) return "less than 1 second";

      var mins = Math.floor(seconds / 60);
      var secs = seconds % 60;

      if (mins > 0) {
        return mins + " min " + secs + " sec";
      }
      return secs + " sec";
    }

    function updateProgress(data) {
      var progress = 0;
      var stage = "idle";
      var eta = null;

      if (data) {
        if (typeof data.progress === "number") {
          progress = data.progress;
        }
        if (data.stage) {
          stage = data.stage;
        }
        if (data.eta_seconds !== undefined) {
          eta = data.eta_seconds;
        }
      }

      progressBar.style.width = progress + "%";
      progressLabel.textContent = "Progress: " + progress + "% (" + stage + ")";
      etaLabel.textContent = "Estimated time remaining: " + formatEta(eta);
    }

    function resetProgress() {
      progressBar.style.width = "0%";
      progressLabel.textContent = "No active job.";
      etaLabel.textContent = "Estimated time remaining: —";
    }

    function formatRaw(data) {
      if (!data) return "No data.";

      var out = "";

      out += "status: " + (data.status || "unknown") + "\n";

      if (data.stage) {
        out += "stage: " + data.stage + "\n";
      }

      if (typeof data.progress === "number") {
        out += "progress: " + data.progress + "%\n";
      }

      if (data.message) {
        out += "message: " + data.message + "\n";
      }

      if (data.error) {
        out += "error: " + data.error + "\n";
      }

      if (data.summary && data.summary.total !== undefined) {
        out += "\nsummary:\n";
        out += "  total: " + data.summary.total + "\n";
      }

      if (data.result) {
        out += "\nresult:\n";
        if (data.result.stl_url) out += "  STL: yes\n";
        if (data.result.png_url) out += "  PNG preview: yes\n";
        if (data.result.zip_url) out += "  ZIP: yes\n";
      }

      return out;
    }

    function renderDownloads(result) {
      downloadsBox.innerHTML = "";

      if (!result) {
        downloadsBox.textContent = "No downloads yet.";
        return;
      }

      var hasLinks = false;

      if (result.stl_url) {
        var a1 = document.createElement("a");
        a1.href = result.stl_url;
        a1.target = "_blank";
        a1.textContent = "Download STL";
        downloadsBox.appendChild(a1);
        hasLinks = true;
      }

      if (result.scad_url) {
        var a2 = document.createElement("a");
        a2.href = result.scad_url;
        a2.target = "_blank";
        a2.textContent = "Download SCAD";
        downloadsBox.appendChild(a2);
        hasLinks = true;
      }

      if (result.png_url) {
        var aPng = document.createElement("a");
        aPng.href = result.png_url;
        aPng.target = "_blank";
        aPng.textContent = "Download PNG";
        downloadsBox.appendChild(aPng);
        hasLinks = true;
      }

      if (result.zip_url) {
        var a3 = document.createElement("a");
        a3.href = result.zip_url;
        a3.target = "_blank";
        a3.textContent = "Download ZIP";
        downloadsBox.appendChild(a3);
        hasLinks = true;
      }

      if (result.region_files && result.region_files.length) {
        for (var i = 0; i < result.region_files.length; i++) {
          var rf = result.region_files[i];

          if (rf.png_url) {
            var arPng = document.createElement("a");
            arPng.href = rf.png_url;
            arPng.target = "_blank";
            arPng.textContent = rf.region + " PNG";
            downloadsBox.appendChild(arPng);
            hasLinks = true;
          }

          if (rf.stl_url) {
            var ar = document.createElement("a");
            ar.href = rf.stl_url;
            ar.target = "_blank";
            ar.textContent = rf.region + " STL";
            downloadsBox.appendChild(ar);
            hasLinks = true;
          }
        }
      }

      if (!hasLinks) {
        downloadsBox.textContent = "No downloads in result.";
      }
    }

    function renderSummary(summary) {
      if (!summary) {
        summaryBox.textContent = "No summary yet.";
        return;
      }

      var html = "";
      html += "<div><strong>Total signatures:</strong> " + summary.total + "</div>";

      for (var i = 0; i < summary.regions.length; i++) {
        var row = summary.regions[i];
        html += '<div class="summary-item"><span>' + row.region + '</span><span>' + row.count + ' total / ' + row.recent_24h + ' recent</span></div>';
      }

      summaryBox.innerHTML = html;
    }

    function renderRegionPreviewPicker(result) {
      latestRegionFiles = [];
      regionPreviewSelect.innerHTML = "";
      regionPreviewWrap.style.display = "none";

      if (!result || !result.region_files || result.region_files.length === 0) {
        return;
      }

      var pngRegions = [];
      for (var i = 0; i < result.region_files.length; i++) {
        if (result.region_files[i].png_url) {
          pngRegions.push(result.region_files[i]);
        }
      }

      if (pngRegions.length === 0) {
        return;
      }

      latestRegionFiles = pngRegions;

      var defaultOption = document.createElement("option");
      defaultOption.value = "";
      defaultOption.textContent = "-- select region preview --";
      regionPreviewSelect.appendChild(defaultOption);

      for (var j = 0; j < pngRegions.length; j++) {
        var option = document.createElement("option");
        option.value = pngRegions[j].png_url;
        option.textContent = pngRegions[j].region;
        regionPreviewSelect.appendChild(option);
      }

      regionPreviewWrap.style.display = "block";
    }

    regionPreviewSelect.addEventListener("change", function () {
      var url = regionPreviewSelect.value;
      if (!url) {
        return;
      }
      updatePreview(url);
    });

    function stopPolling() {
      if (pollTimer) {
        clearTimeout(pollTimer);
        pollTimer = null;
      }
    }

    function choosePreviewUrl(result) {
      if (!result) return null;

      if (result.png_url) return result.png_url;

      if (result.region_files && result.region_files.length > 0) {
        for (var i = 0; i < result.region_files.length; i++) {
          if (result.region_files[i].png_url) {
            return result.region_files[i].png_url;
          }
        }
      }

      return null;
    }

    function pollJob(jobId) {
      var xhr = new XMLHttpRequest();
      xhr.open("GET", "/job/" + encodeURIComponent(jobId), true);

      xhr.onreadystatechange = function () {
        if (xhr.readyState !== 4) {
          return;
        }

        var data = null;
        try {
          data = JSON.parse(xhr.responseText);
        } catch (e) {
          setStatus("Job status returned invalid JSON.", "error");
          setBusy(false);
          stopPolling();
          return;
        }

        rawBox.textContent = formatRaw(data);
        updateProgress(data);

        jobInfoBox.textContent = "Job ID: " + data.job_id + " | Status: " + data.status;
        renderSummary(data.summary);
        renderDownloads(data.result);

        if (data.status === "queued" || data.status === "running") {
          setStatus(data.message || ("Job is " + data.status + "..."));
          setBusy(true);

          var interval = data.status === "queued" ? 2000 : 2500;

          pollTimer = setTimeout(function () {
            pollJob(jobId);
          }, interval);
          return;
        }

        if (data.status === "done") {
          setStatus(data.message || "Job finished.", "success");
          setBusy(false);
          updateProgress(data);
          stopPolling();

          var previewUrl = choosePreviewUrl(data.result);
          updatePreview(previewUrl);
          renderRegionPreviewPicker(data.result);

          if (data.result && data.result.png_warning && !previewUrl) {
            setPreviewStatus(data.result.png_warning);
          }
          return;
        }

        if (data.status === "error") {
          setStatus(data.message || "Job failed.", "error");
          setBusy(false);
          updateProgress(data);
          stopPolling();
          setPreviewStatus("Preview unavailable because the job failed.");
          clearPreview();
          regionPreviewWrap.style.display = "none";
          return;
        }

        setStatus("Unknown job status: " + data.status, "error");
        setBusy(false);
        stopPolling();
      };

      xhr.onerror = function () {
        setStatus("Polling failed.", "error");
        setBusy(false);
        stopPolling();
      };

      xhr.send();
    }

    function startGenerate() {
      var demoFile = document.getElementById("demo_file").value;
      var preset = document.getElementById("preset").value;
      var exportMode = document.getElementById("export_mode").value;
      var sourceMax = document.getElementById("source_max").value;

      if (!demoFile) {
        setStatus("Please choose a demo dataset.", "error");
        return;
      }

      stopPolling();
      setBusy(true);
      setStatus("Submitting job...");
      downloadsBox.textContent = "No downloads yet.";
      summaryBox.textContent = "No summary yet.";
      jobInfoBox.textContent = "Submitting...";
      rawBox.textContent = "Submitting job...";
      setPreviewStatus("Waiting for finished PNG...");
      clearPreview();
      regionPreviewWrap.style.display = "none";
      regionPreviewSelect.innerHTML = "";

      resetProgress();
      progressBar.style.width = "5%";
      progressLabel.textContent = "Progress: 5% (queued)";
      etaLabel.textContent = "Estimated time remaining: calculating...";

      var formData = new FormData();
      formData.append("demo_file", demoFile);
      formData.append("preset", preset);
      formData.append("export_mode", exportMode);
      formData.append("source_max", sourceMax);

      var xhr = new XMLHttpRequest();
      xhr.open("POST", "/generate", true);

      xhr.onreadystatechange = function () {
        if (xhr.readyState !== 4) {
          return;
        }

        var data = null;
        try {
          data = JSON.parse(xhr.responseText);
        } catch (e) {
          setStatus("Generate returned invalid JSON.", "error");
          setBusy(false);
          return;
        }

        rawBox.textContent = formatRaw(data);

        if (xhr.status < 200 || xhr.status >= 300) {
          setStatus(data.error || ("Generate failed with HTTP " + xhr.status), "error");
          setBusy(false);
          return;
        }

        currentJobId = data.job_id;
        jobInfoBox.textContent = "Job ID: " + currentJobId + " | Status: " + data.status;
        setStatus(data.message || "Job started.");
        pollJob(currentJobId);
      };

      xhr.onerror = function () {
        setStatus("Generate request failed.", "error");
        setBusy(false);
      };

      xhr.send(formData);
    }

    button.onclick = startGenerate;
  </script>
</body>
</html>